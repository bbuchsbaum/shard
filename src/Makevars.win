# Makevars.win for shard package (Windows)
#
# Windows uses file-backed memory mapping via CreateFileMapping/MapViewOfFile.
# No special libraries needed beyond the standard Windows API.

PKG_CFLAGS = $(C_VISIBILITY)
# -DUSE_FC_LEN_T: required for F77_CALL(dgemm) with FCONE (WRE 6.6.1).
PKG_CPPFLAGS = -DUSE_FC_LEN_T
PKG_LIBS = $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
